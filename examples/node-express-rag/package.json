{
  "name": "node-express-rag",
  "private": true,
  "version": "0.1.0",
  "description": "Express.js RAG backend example using VelesDB via @wiscale/velesdb-sdk",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -b",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wiscale/velesdb-sdk": "1.15.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.8.0",
    "tsx": "^4.22.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
