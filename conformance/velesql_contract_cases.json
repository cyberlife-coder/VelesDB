{
  "contract_version": "3.0.0",
  "cases": [
    {
      "id": "C001",
      "description": "SELECT query returns contract metadata",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELECT * FROM docs_conformance WHERE vector NEAR $v LIMIT 1",
        "params": { "v": [1.0, 0.0, 0.0, 0.0] }
      },
      "expected_status": 200,
      "expect_contract_meta": true
    },
    {
      "id": "C002",
      "description": "Top-level MATCH via /query requires collection",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "MATCH (d:Doc) RETURN d LIMIT 1",
        "params": {}
      },
      "expected_status": 422,
      "expected_error_code": "VELESQL_MISSING_COLLECTION"
    },
    {
      "id": "C003",
      "description": "Unknown collection returns VELESQL_COLLECTION_NOT_FOUND",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELECT * FROM docs_missing_conformance WHERE vector NEAR $v LIMIT 1",
        "params": { "v": [1.0, 0.0, 0.0, 0.0] }
      },
      "expected_status": 404,
      "expected_error_code": "VELESQL_COLLECTION_NOT_FOUND"
    },
    {
      "id": "C004",
      "description": "Parse error shape remains parser-specific",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELEC * FROM docs_conformance",
        "params": {}
      },
      "expected_status": 400
    },
    {
      "id": "C005",
      "description": "Top-level MATCH via /query succeeds with explicit collection",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "MATCH (d:Doc) RETURN d LIMIT 1",
        "collection": "docs_conformance",
        "params": {}
      },
      "expected_status": 200,
      "expect_contract_meta": true
    },
    {
      "id": "C006",
      "description": "Aggregation query succeeds via /aggregate",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/aggregate",
      "body": {
        "query": "SELECT category, COUNT(*) FROM docs_conformance GROUP BY category",
        "params": {}
      },
      "expected_status": 200,
      "expect_contract_meta": true
    },
    {
      "id": "C007",
      "description": "/aggregate rejects non-aggregation query",
      "runtimes": ["server"],
      "method": "POST",
      "path": "/aggregate",
      "body": {
        "query": "SELECT * FROM docs_conformance LIMIT 1",
        "params": {}
      },
      "expected_status": 422,
      "expected_error_code": "VELESQL_AGGREGATION_ERROR"
    },
    {
      "id": "C008",
      "description": "PR #629: ROW_NUMBER OVER (ORDER BY ...) executes end-to-end",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELECT id, title, ROW_NUMBER() OVER (ORDER BY id DESC) AS rn FROM docs_conformance LIMIT 10",
        "params": {}
      },
      "expected_status": 200,
      "expect_contract_meta": true
    },
    {
      "id": "C009",
      "description": "PR #629: RANK OVER (PARTITION BY ... ORDER BY ...) executes end-to-end",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELECT id, category, RANK() OVER (PARTITION BY category ORDER BY id DESC) AS rk FROM docs_conformance LIMIT 10",
        "params": {}
      },
      "expected_status": 200,
      "expect_contract_meta": true
    },
    {
      "id": "C010",
      "description": "PR #629: DENSE_RANK OVER (ORDER BY ...) executes end-to-end",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELECT id, DENSE_RANK() OVER (ORDER BY id ASC) AS drk FROM docs_conformance LIMIT 10",
        "params": {}
      },
      "expected_status": 200,
      "expect_contract_meta": true
    },
    {
      "id": "C011",
      "description": "PR #629: ROW_NUMBER OVER (PARTITION BY ...) restarts per partition",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELECT id, category, ROW_NUMBER() OVER (PARTITION BY category) AS rn FROM docs_conformance LIMIT 10",
        "params": {}
      },
      "expected_status": 200,
      "expect_contract_meta": true
    },
    {
      "id": "C012",
      "description": "PR #629: multiple window functions in same SELECT",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELECT id, ROW_NUMBER() OVER (ORDER BY id DESC) AS rn, RANK() OVER (ORDER BY id DESC) AS rk FROM docs_conformance LIMIT 10",
        "params": {}
      },
      "expected_status": 200,
      "expect_contract_meta": true
    },
    {
      "id": "C013",
      "description": "PR #629: unsupported window function (NTILE) rejected at parse",
      "runtimes": ["server", "typescript"],
      "method": "POST",
      "path": "/query",
      "body": {
        "query": "SELECT id, NTILE() OVER () FROM docs_conformance",
        "params": {}
      },
      "expected_status": 400
    }
  ]
}
